<view class="page">
  <view class="section panel profile-card">
    <view class="avatar">{{avatarText}}</view>
    <view class="title">我的</view>
    <view class="subtitle">{{user ? "已连接移动端开发登录态" : "账号体系会在接入微信登录后绑定学生、家长和班级。"}}</view>
    <button class="button-primary login-button" loading="{{loggingIn}}" bindtap="login">
      {{user ? "重新登录" : "微信登录"}}
    </button>
  </view>

  <view wx:if="{{user}}" class="section panel">
    <view class="card-title">{{user.nickname}}</view>
    <view class="env-line">角色：{{user.role}}</view>
    <view class="env-line">账号标识：{{user.openid}}</view>
  </view>

  <view class="section panel">
    <view class="card-title">云端环境</view>
    <view class="env-line">服务环境：{{settings.cloud_env_id || "cloud1-d0gxrvlbc5c9f8145"}}</view>
    <view class="env-line">连接方式：{{settings.api_mode || "云函数转发"}}</view>
    <view class="env-line">数据策略：{{settings.database_policy || "演示数据优先，真实后端可接入"}}</view>
  </view>

  <view class="section panel">
    <view class="card-title">已迁移能力</view>
    <view class="feature-grid">
      <block wx:for="{{features}}" wx:key="*this">
        <text>{{item}}</text>
      </block>
    </view>
  </view>

  <view class="section panel">
    <view class="card-title">常用入口</view>
    <button class="button-secondary login-button" bindtap="goKnowledge">管理学习资料</button>
    <button class="button-primary login-button" bindtap="goParent">查看家长周报</button>
  </view>
</view>
