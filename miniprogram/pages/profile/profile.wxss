.profile-page {
  padding-bottom: 64rpx;
}

.hero-panel {
  background: transparent;
  border-bottom: 1rpx solid #e6dfd8;
  border-radius: 0;
  color: #141413;
  padding: 0 0 28rpx;
}

.hero-top {
  align-items: center;
  display: flex;
  gap: 24rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-panel .title {
  color: #141413;
  font-size: 48rpx;
}

.hero-panel .subtitle {
  color: #6c6a64;
}

.hero-actions,
.button-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 26rpx;
}

.privacy-check {
  background: #fbf6ee;
  border: 1rpx solid #e6dfd8;
  border-radius: 14rpx;
  color: #6c6a64;
  font-size: 23rpx;
  line-height: 1.45;
  margin-top: 22rpx;
  padding: 16rpx 18rpx;
}

.privacy-check label {
  align-items: center;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.privacy-link {
  color: #c9674f;
}

.action-button,
.compact-button {
  flex: 1 1 196rpx;
  min-width: 0;
  padding: 0 18rpx;
}

.full-button {
  margin-top: 22rpx;
  width: 100%;
}

.section-head {
  align-items: flex-start;
  display: flex;
  gap: 18rpx;
  justify-content: space-between;
}

.model-note {
  color: #71645b;
  font-size: 24rpx;
  line-height: 1.5;
  margin-top: 8rpx;
}

.profile-page .panel {
  background: transparent;
  border-width: 0 0 1rpx;
  border-radius: 0;
  padding: 0 0 28rpx;
}

.info-grid {
  border-top: 1rpx solid #e6dfd8;
  display: flex;
  flex-direction: column;
  margin-top: 22rpx;
}

.info-item {
  border-bottom: 1rpx solid #e6dfd8;
  min-height: 0;
  padding: 18rpx 0;
}

.label,
.field-label {
  color: #8b7565;
  display: block;
  font-size: 23rpx;
  line-height: 1.3;
}

.value {
  color: #2b2722;
  display: block;
  font-size: 27rpx;
  line-height: 1.4;
  margin-top: 6rpx;
  word-break: break-all;
}

.status-list,
.form-list,
.deploy-list,
.contact-list {
  margin-top: 22rpx;
}

.status-row {
  align-items: center;
  border-bottom: 1rpx solid #e3d5c7;
  color: #2b2722;
  display: flex;
  font-size: 25rpx;
  justify-content: space-between;
  line-height: 1.5;
  padding: 16rpx 0;
}

.status-row:last-child {
  border-bottom: 0;
}

.status-row text:first-child {
  color: #8b7565;
  flex: 0 0 150rpx;
}

.status-row text:last-child {
  flex: 1;
  text-align: right;
  word-break: break-all;
}

.contact-panel {
  color: #141413;
}

.contact-row {
  align-items: center;
  border-bottom: 1rpx solid #e6dfd8;
  color: #141413;
  display: flex;
  font-size: 25rpx;
  justify-content: space-between;
  line-height: 1.5;
  padding: 17rpx 0;
}

.contact-row:last-child {
  border-bottom: 0;
}

.contact-row text:first-child {
  color: #8b7565;
}

.contact-row text:last-child {
  color: #141413;
  text-align: right;
  word-break: break-all;
}

.field {
  margin-top: 20rpx;
}

.field-input {
  background: #fbf6ee;
  border: 1rpx solid #e6dfd8;
  border-radius: 12rpx;
  color: #2b2722;
  font-size: 26rpx;
  height: 76rpx;
  margin-top: 10rpx;
  padding: 0 18rpx;
  width: 100%;
}

.toggle-row {
  align-items: center;
  border-top: 1rpx solid #e3d5c7;
  display: flex;
  gap: 18rpx;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
}

.toggle-row > view {
  flex: 1;
  min-width: 0;
}

.toggle-title {
  color: #2b2722;
  font-size: 27rpx;
  line-height: 1.4;
}

.connection-panel {
  border-color: #e3d5c7;
}

.connection-panel.success {
  border-color: #9bc59c;
}

.connection-panel.error {
  border-color: #de9a8d;
}

.connection-result {
  align-items: center;
  border-top: 1rpx solid #e6dfd8;
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 18rpx;
}

.connection-label {
  color: #2b2722;
  font-size: 28rpx;
  font-weight: 500;
}

.connection-latency {
  color: #b86347;
  font-size: 24rpx;
}

.deploy-item {
  align-items: flex-start;
  color: #3d352e;
  display: flex;
  font-size: 25rpx;
  gap: 14rpx;
  line-height: 1.55;
  margin-top: 16rpx;
}

.deploy-dot {
  border-radius: 50%;
  flex: 0 0 16rpx;
  height: 16rpx;
  margin-top: 12rpx;
  width: 16rpx;
}

.deploy-dot.ready {
  background: #70a06e;
}

.deploy-dot.testing {
  background: #cc785c;
}

.deploy-dot.pending {
  background: #b8a18a;
}
