.profile-card {
  align-items: center;
  display: flex;
  flex-direction: column;
  text-align: center;
}

.avatar {
  align-items: center;
  background: #181715;
  border-radius: 50%;
  color: #faf9f5;
  display: flex;
  font-size: 42rpx;
  height: 112rpx;
  justify-content: center;
  margin-bottom: 24rpx;
  width: 112rpx;
}

.login-button {
  margin-top: 26rpx;
  min-width: 260rpx;
}

.env-line {
  color: #3d3d3a;
  font-size: 25rpx;
  line-height: 1.6;
  margin-top: 10rpx;
  word-break: break-all;
}

.feature-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.feature-grid text {
  background: #faf9f5;
  border: 1rpx solid #e6dfd8;
  border-radius: 999rpx;
  color: #cc785c;
  font-size: 23rpx;
  padding: 12rpx 18rpx;
}
