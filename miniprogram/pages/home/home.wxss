.home-page {
  padding-bottom: 48rpx;
}

.hero {
  background: #171511;
  border: 1rpx solid #2b2721;
  border-radius: 22rpx;
  box-shadow: 0 18rpx 42rpx rgba(23, 21, 17, 0.18);
  padding: 30rpx 28rpx 34rpx;
}

.hero-brand {
  align-items: center;
  display: flex;
  gap: 12rpx;
}

.hero-mark {
  align-items: center;
  background: #c9674f;
  border-radius: 14rpx;
  color: #fff7ed;
  display: flex;
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 22rpx;
  height: 52rpx;
  justify-content: center;
  width: 52rpx;
}

.hero-kicker {
  color: #e7a38b;
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.hero-title {
  color: #fff7ed;
  font-size: 56rpx;
  margin-top: 20rpx;
}

.hero-copy {
  color: #cfc4b5;
  font-size: 26rpx;
  line-height: 1.55;
  margin-top: 14rpx;
}

.grid {
  display: grid;
  gap: 14rpx;
  grid-template-columns: repeat(3, 1fr);
}

.metric {
  background: #f3eadc;
  padding: 24rpx 12rpx;
  text-align: center;
}

.metric-icon {
  align-items: center;
  background: #171511;
  border-radius: 12rpx;
  color: #fff7ed;
  display: flex;
  font-size: 21rpx;
  font-weight: 600;
  height: 42rpx;
  justify-content: center;
  margin: 0 auto 12rpx;
  width: 42rpx;
}

.metric-icon.coral {
  background: #c9674f;
}

.metric-icon.gold {
  background: #d89945;
}

.metric-value {
  color: #141413;
  display: block;
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 40rpx;
  line-height: 1.1;
}

.metric-label {
  color: #6c6a64;
  display: block;
  font-size: 22rpx;
  margin-top: 10rpx;
}

.active-card {
  background: #171511;
  border-color: #2b2721;
  padding: 28rpx;
}

.active-copy {
  flex: 1;
  min-width: 0;
}

.active-card .card-title {
  color: #fff7ed;
}

.active-card .subtitle {
  color: #a09d96;
}

.compact {
  height: 64rpx;
  line-height: 64rpx;
  min-width: 116rpx;
  padding: 0 22rpx;
}

.active-card .button-secondary {
  background: #29251f;
  border-color: #3a3833;
  color: #fff7ed;
}

.inline-icon {
  align-items: center;
  background: #c9674f;
  border-radius: 10rpx;
  color: #fff7ed;
  display: inline-flex;
  font-size: 20rpx;
  height: 36rpx;
  justify-content: center;
  margin-right: 10rpx;
  vertical-align: middle;
  width: 36rpx;
}

.inline-icon.dark {
  background: #171511;
}

.section-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.text-button {
  background: transparent;
  color: #c9674f;
  font-size: 24rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0;
}

.capability-grid {
  display: grid;
  gap: 14rpx;
  grid-template-columns: repeat(2, 1fr);
}

.capability-card {
  border: 1rpx solid #e2d5c6;
  border-radius: 16rpx;
  min-height: 192rpx;
  padding: 22rpx;
}

.capability-card.coral,
.capability-card.amber,
.capability-card.teal {
  background: #f3eadc;
}

.capability-card.dark {
  background: #171511;
  border-color: #2b2721;
}

.capability-card.dark .capability-title,
.capability-card.dark .capability-desc {
  color: #fff7ed;
}

.capability-card.dark .capability-desc {
  color: #a09d96;
}

.capability-icon {
  align-items: center;
  background: #c9674f;
  border-radius: 14rpx;
  color: #ffffff;
  display: flex;
  font-size: 26rpx;
  height: 56rpx;
  justify-content: center;
  width: 56rpx;
}

.capability-card.dark .capability-icon {
  background: #29251f;
}

.capability-card.amber .capability-icon {
  background: #e8a55a;
}

.capability-card.teal .capability-icon {
  background: #5db8a6;
}

.capability-title {
  color: #141413;
  font-size: 28rpx;
  font-weight: 500;
  margin-top: 18rpx;
}

.capability-desc {
  color: #6c6a64;
  font-size: 23rpx;
  line-height: 1.45;
  margin-top: 8rpx;
}

.action-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.action {
  align-items: center;
  background: #f3eadc;
  display: flex;
  gap: 24rpx;
}

.action-icon {
  align-items: center;
  border-radius: 16rpx;
  color: #ffffff;
  display: flex;
  flex: 0 0 76rpx;
  font-size: 30rpx;
  font-weight: 500;
  height: 76rpx;
  justify-content: center;
  width: 76rpx;
}

.action-icon.green {
  background: #5db8a6;
}

.action-icon.amber {
  background: #e8a55a;
}

.bot-panel {
  background: #f7efe5;
}

.bot-row {
  align-items: center;
  border-top: 1rpx solid #e6dfd8;
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
}

.bot-dot {
  background: #5db872;
  border-radius: 50%;
  height: 14rpx;
  width: 14rpx;
}

.bot-name {
  color: #141413;
  font-size: 26rpx;
  font-weight: 500;
}

.bot-desc {
  color: #6c6a64;
  font-size: 23rpx;
  margin-top: 4rpx;
}
