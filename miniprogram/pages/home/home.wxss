.home-page {
  padding-bottom: 48rpx;
}

.hero {
  background: #faf9f5;
  border-bottom: 1rpx solid #ebe6df;
  padding: 26rpx 6rpx 34rpx;
}

.hero-kicker {
  color: #cc785c;
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.hero-title {
  color: #141413;
  font-size: 56rpx;
  margin-top: 20rpx;
}

.grid {
  display: grid;
  gap: 14rpx;
  grid-template-columns: repeat(3, 1fr);
}

.metric {
  background: #efe9de;
  padding: 24rpx 12rpx;
  text-align: center;
}

.metric-value {
  color: #141413;
  display: block;
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 40rpx;
  line-height: 1.1;
}

.metric-label {
  color: #6c6a64;
  display: block;
  font-size: 22rpx;
  margin-top: 10rpx;
}

.active-card {
  background: #181715;
  border-color: #252320;
  padding: 28rpx;
}

.active-copy {
  flex: 1;
  min-width: 0;
}

.active-card .card-title {
  color: #faf9f5;
}

.active-card .subtitle {
  color: #a09d96;
}

.compact {
  height: 64rpx;
  line-height: 64rpx;
  min-width: 116rpx;
  padding: 0 22rpx;
}

.active-card .button-secondary {
  background: #252320;
  border-color: #3a3833;
  color: #faf9f5;
}

.section-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.text-button {
  background: transparent;
  color: #cc785c;
  font-size: 24rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0;
}

.capability-grid {
  display: grid;
  gap: 14rpx;
  grid-template-columns: repeat(2, 1fr);
}

.capability-card {
  border: 1rpx solid #e6dfd8;
  border-radius: 16rpx;
  min-height: 192rpx;
  padding: 22rpx;
}

.capability-card.coral,
.capability-card.amber,
.capability-card.teal {
  background: #efe9de;
}

.capability-card.dark {
  background: #181715;
  border-color: #252320;
}

.capability-card.dark .capability-title,
.capability-card.dark .capability-desc {
  color: #faf9f5;
}

.capability-card.dark .capability-desc {
  color: #a09d96;
}

.capability-icon {
  align-items: center;
  background: #cc785c;
  border-radius: 14rpx;
  color: #ffffff;
  display: flex;
  font-size: 26rpx;
  height: 56rpx;
  justify-content: center;
  width: 56rpx;
}

.capability-card.dark .capability-icon {
  background: #252320;
}

.capability-card.amber .capability-icon {
  background: #e8a55a;
}

.capability-card.teal .capability-icon {
  background: #5db8a6;
}

.capability-title {
  color: #141413;
  font-size: 28rpx;
  font-weight: 500;
  margin-top: 18rpx;
}

.capability-desc {
  color: #6c6a64;
  font-size: 23rpx;
  line-height: 1.45;
  margin-top: 8rpx;
}

.action-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.action {
  align-items: center;
  background: #efe9de;
  display: flex;
  gap: 24rpx;
}

.action-icon {
  align-items: center;
  border-radius: 16rpx;
  color: #ffffff;
  display: flex;
  flex: 0 0 76rpx;
  font-size: 30rpx;
  font-weight: 500;
  height: 76rpx;
  justify-content: center;
  width: 76rpx;
}

.action-icon.green {
  background: #5db8a6;
}

.action-icon.amber {
  background: #e8a55a;
}

.bot-panel {
  background: #f5f0e8;
}

.bot-row {
  align-items: center;
  border-top: 1rpx solid #e6dfd8;
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
}

.bot-dot {
  background: #5db872;
  border-radius: 50%;
  height: 14rpx;
  width: 14rpx;
}

.bot-name {
  color: #141413;
  font-size: 26rpx;
  font-weight: 500;
}

.bot-desc {
  color: #6c6a64;
  font-size: 23rpx;
  margin-top: 4rpx;
}
