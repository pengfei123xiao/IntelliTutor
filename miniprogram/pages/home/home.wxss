.home-page {
  padding-bottom: 48rpx;
}

.hero {
  border-bottom: 1rpx solid #e6dfd8;
  padding-bottom: 24rpx;
}

.hero-title {
  color: #141413;
  font-size: 50rpx;
}

.metric-strip {
  border-bottom: 1rpx solid #e6dfd8;
  border-top: 1rpx solid #e6dfd8;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  padding: 18rpx 0;
}

.metric {
  border-right: 1rpx solid #e6dfd8;
  padding: 4rpx 12rpx;
  text-align: center;
}

.metric:last-child {
  border-right: 0;
}

.metric-value {
  color: #141413;
  display: block;
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 40rpx;
  line-height: 1.1;
}

.metric-label {
  color: #6c6a64;
  display: block;
  font-size: 22rpx;
  margin-top: 10rpx;
}

.active-card,
.bot-panel {
  background: transparent;
  border-width: 0 0 1rpx;
  border-radius: 0;
  padding: 0 0 24rpx;
}

.active-copy {
  flex: 1;
  min-width: 0;
}

.compact {
  height: 64rpx;
  line-height: 64rpx;
  min-width: 116rpx;
  padding: 0 22rpx;
}

.section-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.text-button {
  background: transparent;
  color: #c9674f;
  font-size: 24rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0;
}

.capability-grid {
  border-top: 1rpx solid #e6dfd8;
  display: flex;
  flex-direction: column;
}

.capability-card {
  border-bottom: 1rpx solid #e6dfd8;
  padding: 22rpx 0;
}

.capability-title,
.bot-name {
  color: #141413;
  font-size: 28rpx;
  font-weight: 500;
}

.action-list {
  border-top: 1rpx solid #e6dfd8;
  display: flex;
  flex-direction: column;
}

.action {
  align-items: center;
  border-bottom: 1rpx solid #e6dfd8;
  display: flex;
  min-height: 84rpx;
}

.bot-row {
  border-top: 1rpx solid #e6dfd8;
  margin-top: 16rpx;
  padding-top: 16rpx;
}

.bot-desc {
  color: #6c6a64;
  font-size: 23rpx;
  margin-top: 4rpx;
}
