.home-page {
  padding-bottom: 48rpx;
}

.hero {
  border-bottom: 1rpx solid #e6dfd8;
  padding-bottom: 24rpx;
}

.hero-title {
  color: #141413;
  font-size: 50rpx;
}

.metric-strip {
  background: #faf9f5;
  border: 1rpx solid #e6dfd8;
  border-radius: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  padding: 18rpx 0;
}

.metric {
  border-right: 1rpx solid #e6dfd8;
  padding: 4rpx 12rpx;
  text-align: center;
}

.metric:last-child {
  border-right: 0;
}

.metric-value {
  color: #141413;
  display: block;
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 40rpx;
  line-height: 1.1;
}

.metric-label {
  color: #6c6a64;
  display: block;
  font-size: 22rpx;
  margin-top: 10rpx;
}

.line-section {
  background: #f5f0e8;
  border: 1rpx solid #e6dfd8;
  border-radius: 18rpx;
  padding: 26rpx 24rpx;
}

.section-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  padding: 0 0 18rpx;
}

.section-note {
  color: #8e8b82;
  font-size: 22rpx;
  line-height: 1.45;
  margin-top: 6rpx;
}

.text-button {
  background: #faf9f5;
  border: 1rpx solid #e2d5c6;
  border-radius: 999rpx;
  color: #c9674f;
  font-size: 24rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 22rpx;
}

.line-row {
  align-items: center;
  border-bottom: 1rpx solid #e6dfd8;
  display: flex;
  justify-content: space-between;
  min-height: 92rpx;
  padding: 18rpx 0;
}

.line-section .line-row:last-child,
.line-section .plain-line:last-child {
  border-bottom: 0;
}

.row-copy {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
}

.row-title,
.today-title {
  color: #141413;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.35;
}

.row-meta {
  color: #6c6a64;
  font-size: 23rpx;
  line-height: 1.45;
  margin-top: 8rpx;
}

.row-status {
  border: 1rpx solid #e2d5c6;
  border-radius: 999rpx;
  color: #6c6a64;
  flex: 0 0 auto;
  font-size: 22rpx;
  line-height: 1;
  padding: 10rpx 16rpx;
}

.row-status.warm {
  color: #c9674f;
}

.graph-panel {
  border-radius: 16rpx;
  padding: 28rpx;
}

.graph-head {
  align-items: flex-start;
  display: flex;
  justify-content: space-between;
}

.dark-title {
  color: #faf9f5;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 1.35;
}

.dark-meta {
  color: #a09d96;
  font-size: 23rpx;
  line-height: 1.45;
  margin-top: 8rpx;
}

.graph-score {
  color: #faf9f5;
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 50rpx;
  line-height: 1;
}

.graph-map {
  background: #201d19;
  border: 1rpx solid #2b2721;
  border-radius: 16rpx;
  height: 286rpx;
  margin-top: 26rpx;
  overflow: hidden;
  position: relative;
}

.graph-map::after {
  background: rgba(204, 120, 92, 0.18);
  border-radius: 999rpx;
  content: "";
  height: 130rpx;
  left: 50%;
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 130rpx;
}

.graph-edge {
  background: #3c342d;
  height: 2rpx;
  left: 118rpx;
  position: absolute;
  top: 142rpx;
  transform-origin: left center;
  width: 310rpx;
}

.edge-a {
  transform: rotate(-22deg);
}

.edge-b {
  transform: rotate(19deg);
}

.edge-c {
  left: 210rpx;
  transform: rotate(90deg);
  width: 168rpx;
}

.graph-node {
  align-items: center;
  background: #2a2620;
  border: 1rpx solid #3a332d;
  border-radius: 999rpx;
  display: flex;
  flex-direction: column;
  height: 104rpx;
  justify-content: center;
  padding: 0 16rpx;
  position: absolute;
  width: 176rpx;
  z-index: 1;
}

.graph-node.selected {
  border-color: #faf9f5;
  box-shadow: 0 0 0 4rpx rgba(250, 249, 245, 0.08);
}

.graph-node.weak {
  background: #3a241f;
  border-color: #cc785c;
}

.graph-node.strong {
  background: #21312c;
  border-color: #5db8a6;
}

.node-0 {
  left: 28rpx;
  top: 28rpx;
}

.node-1 {
  right: 28rpx;
  top: 42rpx;
}

.node-2 {
  bottom: 34rpx;
  left: 96rpx;
}

.node-3 {
  bottom: 28rpx;
  right: 70rpx;
}

.node-title {
  color: #faf9f5;
  display: block;
  font-size: 24rpx;
  line-height: 1.25;
  max-width: 138rpx;
  overflow: hidden;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.node-meta {
  color: #a09d96;
  display: block;
  font-size: 20rpx;
  line-height: 1.2;
  margin-top: 8rpx;
}

.graph-node.weak .node-meta {
  color: #e6b19c;
}

.graph-node.strong .node-meta {
  color: #91d0c1;
}

.graph-detail {
  background: #252320;
  border: 1rpx solid #3a332d;
  border-radius: 14rpx;
  margin-top: 18rpx;
  padding: 22rpx;
}

.graph-detail-head {
  align-items: flex-start;
  display: flex;
  justify-content: space-between;
}

.detail-title {
  color: #faf9f5;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.35;
}

.detail-subtitle {
  color: #e6b19c;
  font-size: 22rpx;
  line-height: 1.4;
  margin-top: 6rpx;
}

.detail-close {
  align-items: center;
  background: #181715;
  border: 1rpx solid #3a332d;
  border-radius: 999rpx;
  color: #faf9f5;
  display: flex;
  font-size: 30rpx;
  height: 46rpx;
  justify-content: center;
  line-height: 1;
  margin: 0;
  padding: 0;
  width: 46rpx;
}

.detail-grid {
  display: grid;
  gap: 14rpx;
  grid-template-columns: repeat(2, 1fr);
  margin-top: 20rpx;
}

.detail-item {
  background: #181715;
  border: 1rpx solid #2b2721;
  border-radius: 12rpx;
  min-width: 0;
  padding: 16rpx;
}

.detail-item text:first-child,
.detail-action text:first-child {
  color: #a09d96;
  display: block;
  font-size: 21rpx;
  line-height: 1.35;
}

.detail-item text:last-child,
.detail-action text:last-child {
  color: #faf9f5;
  display: block;
  font-size: 25rpx;
  line-height: 1.35;
  margin-top: 8rpx;
  word-break: break-all;
}

.detail-action {
  align-items: center;
  background: #181715;
  border: 1rpx solid #2b2721;
  border-radius: 12rpx;
  display: flex;
  justify-content: space-between;
  margin-top: 14rpx;
  padding: 16rpx;
}

.detail-action view {
  flex: 1;
  min-width: 0;
  padding-right: 18rpx;
}

.detail-button {
  background: #cc785c;
  border: 0;
  border-radius: 8rpx;
  color: #ffffff;
  flex: 0 0 auto;
  font-size: 23rpx;
  height: 52rpx;
  line-height: 52rpx;
  margin: 0;
  padding: 0 22rpx;
}

.detail-note {
  margin-top: 14rpx;
}

.graph-lines {
  border-top: 1rpx solid #2b2721;
  margin-top: 26rpx;
}

.graph-line {
  align-items: center;
  border-bottom: 1rpx solid #2b2721;
  color: #faf9f5;
  display: flex;
  font-size: 24rpx;
  justify-content: space-between;
  line-height: 1.45;
  min-height: 70rpx;
}

.graph-line text:first-child {
  color: #a09d96;
  flex: 0 0 auto;
  padding-right: 20rpx;
}

.graph-line text:last-child {
  flex: 1;
  text-align: right;
}

.today-title {
  padding-bottom: 12rpx;
}

.plain-line {
  border-bottom: 1rpx solid #e6dfd8;
  color: #3d3d3a;
  font-size: 25rpx;
  line-height: 1.45;
  padding: 18rpx 0;
}

.weekly-strip {
  background: #faf9f5;
  border: 1rpx solid #e6dfd8;
  border-radius: 14rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin-top: 8rpx;
  overflow: hidden;
}

.weekly-metric {
  border-right: 1rpx solid #e6dfd8;
  padding: 18rpx 10rpx;
  text-align: center;
}

.weekly-metric:last-child {
  border-right: 0;
}

.weekly-metric text:first-child {
  color: #141413;
  display: block;
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 34rpx;
  line-height: 1.1;
}

.weekly-metric text:last-child {
  color: #8e8b82;
  display: block;
  font-size: 21rpx;
  line-height: 1.35;
  margin-top: 8rpx;
}

.weekly-row {
  border-bottom: 0;
}

.weekly-summary {
  background: #faf9f5;
  border: 1rpx solid #e6dfd8;
  border-radius: 12rpx;
  color: #3d3d3a;
  font-size: 24rpx;
  line-height: 1.5;
  padding: 18rpx 20rpx;
}

.last-section {
  margin-bottom: 18rpx;
}

.home-note {
  margin-top: 4rpx;
}
