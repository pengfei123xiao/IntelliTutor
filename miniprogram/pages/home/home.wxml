<view class="page home-page">
  <view class="hero section">
    <view class="title hero-title">学习</view>
    <view class="subtitle">今天从书、图谱和复盘开始。</view>
  </view>

  <view class="section metric-strip">
    <view class="metric">
      <text class="metric-value">{{stats.books}}</text>
      <text class="metric-label">书籍</text>
    </view>
    <view class="metric">
      <text class="metric-value">{{stats.mastery}}</text>
      <text class="metric-label">掌握</text>
    </view>
    <view class="metric">
      <text class="metric-value">{{stats.wrong}}</text>
      <text class="metric-label">错题</text>
    </view>
  </view>

  <view class="section line-section">
    <view class="section-head">
      <view>
        <view class="card-title">书架</view>
        <view class="section-note">{{notesLabel}}</view>
      </view>
      <button class="text-button" bindtap="goKnowledge">管理</button>
    </view>
    <block wx:for="{{books}}" wx:key="title">
      <view class="line-row" bindtap="goKnowledge">
        <view class="row-copy">
          <view class="row-title">{{item.title}}</view>
          <view class="row-meta">{{item.meta}}</view>
        </view>
        <text class="row-status">{{item.status}}</text>
      </view>
    </block>
  </view>

  <view class="section dark-panel graph-panel" bindtap="goReport">
    <view class="graph-head">
      <view>
        <view class="dark-title">个人知识图谱</view>
        <view class="dark-meta">{{graph.updated}}</view>
      </view>
      <text class="graph-score">{{graph.mastery}}</text>
    </view>
    <view class="graph-lines">
      <view class="graph-line">
        <text>状态</text>
        <text>{{graph.label}}</text>
      </view>
      <view class="graph-line">
        <text>薄弱节点</text>
        <text>{{graph.weakCount}}</text>
      </view>
      <view class="graph-line">
        <text>优先复习</text>
        <text>{{graph.focus}}</text>
      </view>
    </view>
  </view>

  <view class="section line-section">
    <view class="section-head">
      <view>
        <view class="card-title">今日学习</view>
        <view class="section-note">{{today.meta}}</view>
      </view>
      <button class="text-button" bindtap="goGuide">继续</button>
    </view>
    <view class="today-title">{{today.title}}</view>
    <block wx:for="{{today.tasks}}" wx:key="*this">
      <view class="plain-line">{{item}}</view>
    </block>
  </view>

  <view class="section line-section">
    <view class="section-head">
      <view>
        <view class="card-title">错题复盘</view>
        <view class="section-note">正确率 {{review.accuracy}}</view>
      </view>
      <button class="text-button" bindtap="goKnowledge">查看</button>
    </view>
    <view class="line-row" bindtap="goKnowledge">
      <view class="row-copy">
        <view class="row-title">{{review.focus}}</view>
        <view class="row-meta">待复盘 {{review.count}} 题</view>
      </view>
      <text class="row-status warm">复盘</text>
    </view>
  </view>

  <view class="section line-section last-section">
    <view class="section-head">
      <view class="card-title">最近学习</view>
    </view>
    <block wx:for="{{recentLearning}}" wx:key="title">
      <view class="line-row" bindtap="goReport">
        <view class="row-copy">
          <view class="row-title">{{item.title}}</view>
          <view class="row-meta">{{item.meta}}</view>
        </view>
      </view>
    </block>
  </view>

  <text class="ai-note home-note">掌握度和建议由学习记录估算，仅供参考。</text>
</view>
