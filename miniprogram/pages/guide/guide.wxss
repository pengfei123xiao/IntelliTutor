.create-panel {
  background: transparent;
  border-width: 0 0 1rpx;
  border-radius: 0;
  padding: 0 0 28rpx;
}

.topic-input {
  background: #fbf6ee;
  border: 1rpx solid #e6dfd8;
  border-radius: 16rpx;
  color: #141413;
  font-size: 27rpx;
  line-height: 1.55;
  margin-top: 24rpx;
  min-height: 150rpx;
  padding: 22rpx;
  width: 100%;
}

.template-list {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.template-list text {
  background: #efe9de;
  border: 1rpx solid #e6dfd8;
  border-radius: 999rpx;
  color: #3d3d3a;
  display: inline-flex;
  font-size: 24rpx;
  line-height: 1;
  padding: 16rpx 20rpx;
}

.start-button {
  margin-top: 24rpx;
}

.section-title {
  color: #141413;
  font-size: 31rpx;
  font-weight: 500;
  margin-bottom: 18rpx;
}

.session {
  background: transparent;
  border-width: 0 0 1rpx;
  border-radius: 0;
  margin-bottom: 0;
  padding: 24rpx 0;
}

.session-title {
  color: #141413;
  flex: 1;
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 34rpx;
  line-height: 1.25;
}

.task-list {
  border-top: 1rpx solid #e6dfd8;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 18rpx;
  padding-top: 16rpx;
}

.task-list text {
  color: #3d3d3a;
  font-size: 25rpx;
  line-height: 1.45;
}

.continue-button {
  margin-top: 18rpx;
}
