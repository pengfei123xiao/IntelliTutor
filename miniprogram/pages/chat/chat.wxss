.chat-page {
  background:
    linear-gradient(180deg, #faf9f5 0, #faf9f5 148rpx, #fbf6ee 58%, #efe5d8 100%);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  width: 100vw;
}

.chat-topbar {
  align-items: center;
  background: #faf9f5;
  border-bottom: 1rpx solid #e6dfd8;
  display: flex;
  gap: 14rpx;
  justify-content: space-between;
  min-height: 92rpx;
  padding: 16rpx 28rpx 18rpx;
}

.top-actions {
  display: flex;
  flex: 1;
  gap: 14rpx;
  justify-content: flex-end;
  min-width: 0;
}

.top-button {
  align-items: center;
  background: #faf9f5;
  border: 1rpx solid #e6dfd8;
  border-radius: 999rpx;
  color: #3d3d3a;
  display: flex;
  flex: 1;
  font-size: 25rpx;
  font-weight: 500;
  height: 58rpx;
  justify-content: center;
  line-height: 1;
  max-width: 310rpx;
  min-width: 0;
  padding: 0 20rpx;
}

.top-button.primary {
  background: #181715;
  border-color: #181715;
  color: #faf9f5;
  max-width: 330rpx;
}

.button-icon {
  border-color: currentColor;
  display: inline-block;
  margin-right: 7rpx;
  position: relative;
}

.history-icon {
  border-top: 3rpx solid;
  height: 16rpx;
  width: 22rpx;
}

.history-icon::before,
.history-icon::after {
  border-top: 3rpx solid;
  content: "";
  left: 0;
  position: absolute;
  width: 22rpx;
}

.history-icon::before {
  top: 6rpx;
}

.history-icon::after {
  top: 15rpx;
}

.plus-icon {
  height: 22rpx;
  width: 22rpx;
}

.plus-icon::before,
.plus-icon::after {
  background: currentColor;
  border-radius: 3rpx;
  content: "";
  left: 50%;
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
}

.plus-icon::before {
  height: 3rpx;
  width: 22rpx;
}

.plus-icon::after {
  height: 22rpx;
  width: 3rpx;
}

.message-list {
  flex: 1;
  min-height: 0;
  overflow: hidden;
  width: 100%;
}

.message-content {
  box-sizing: border-box;
  padding: 36rpx 30rpx 24rpx;
  width: 100%;
}

.message-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 26rpx;
}

.message-head text {
  color: #6c6a64;
  font-size: 24rpx;
  font-weight: 500;
}

.small-outline {
  background: #fbf6ee;
  border: 1rpx solid #e2d5c6;
  border-radius: 14rpx;
  color: #6c6a64;
  font-size: 23rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 18rpx;
}

.empty-chat {
  align-items: center;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 61vh;
  text-align: center;
}

.empty-orbit {
  align-items: center;
  background: #171511;
  border: 1rpx solid #2f2a23;
  border-radius: 34rpx;
  box-shadow: 0 18rpx 40rpx rgba(23, 21, 17, 0.22);
  display: flex;
  height: 108rpx;
  justify-content: center;
  margin-bottom: 24rpx;
  width: 108rpx;
}

.orbit-mark {
  align-items: center;
  background: #c9674f;
  border-radius: 50%;
  color: #fff7ed;
  display: flex;
  font-size: 34rpx;
  font-weight: 600;
  height: 66rpx;
  justify-content: center;
  width: 66rpx;
}

.empty-kicker {
  color: #c9674f;
  font-size: 23rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  margin-bottom: 12rpx;
}

.empty-title {
  color: #141413;
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 54rpx;
  font-weight: 400;
  line-height: 1.16;
}

.empty-copy {
  color: #71685e;
  font-size: 26rpx;
  line-height: 1.55;
  margin-top: 18rpx;
}

.empty-prompts {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 34rpx;
  width: 100%;
}

.empty-prompts view {
  background: #fff9f0;
  border: 1rpx solid #e2d5c6;
  border-radius: 18rpx;
  color: #3d3d3a;
  display: grid;
  font-size: 27rpx;
  grid-template-columns: 64rpx 1fr;
  line-height: 1.45;
  padding: 22rpx;
  text-align: left;
}

.prompt-icon {
  align-items: center;
  background: #171511;
  border-radius: 16rpx;
  color: #fff7ed;
  display: flex;
  font-size: 25rpx;
  font-weight: 600;
  grid-row: span 2;
  height: 52rpx;
  justify-content: center;
  margin-top: 2rpx;
  width: 52rpx;
}

.prompt-icon.coral {
  background: #c9674f;
}

.prompt-icon.gold {
  background: #d89945;
}

.prompt-title {
  color: #171511;
  display: block;
  font-size: 28rpx;
  font-weight: 600;
}

.prompt-desc {
  color: #71685e;
  display: block;
  font-size: 23rpx;
  margin-top: 4rpx;
}

.message {
  box-sizing: border-box;
  display: flex;
  margin-bottom: 26rpx;
  min-width: 0;
  overflow: hidden;
  width: 100%;
}

.message.user {
  justify-content: flex-end;
}

.message.assistant,
.message.status {
  justify-content: flex-start;
}

.bubble {
  box-sizing: border-box;
  font-size: 29rpx;
  line-height: 1.68;
  max-width: 88%;
  min-width: 0;
  overflow: hidden;
  padding: 0;
  white-space: normal;
  word-break: break-all;
  word-wrap: break-word;
}

.user .bubble {
  background: #f3eadc;
  border-radius: 28rpx;
  color: #141413;
  padding: 20rpx 24rpx;
}

.assistant .bubble {
  color: #141413;
  max-width: 100%;
}

.message-text {
  display: block;
  max-width: 100%;
  overflow: hidden;
  white-space: pre-wrap;
  word-break: break-all;
  word-wrap: break-word;
}

.message-attachments {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.message-attachments text {
  background: #fbf6ee;
  border: 1rpx solid #e2d5c6;
  border-radius: 999rpx;
  color: #6c6a64;
  font-size: 22rpx;
  max-width: 360rpx;
  overflow: hidden;
  padding: 8rpx 14rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.message-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 14rpx;
}

.message-actions text {
  color: #8e8b82;
  font-size: 22rpx;
}

.status .bubble {
  background: #f7efe5;
  border: 1rpx solid #e2d5c6;
  border-radius: 14rpx;
  color: #a9583e;
  font-size: 24rpx;
  padding: 12rpx 16rpx;
}

.composer {
  background: #1c1915;
  border: 1rpx solid #332d25;
  border-radius: 26rpx;
  box-sizing: border-box;
  box-shadow: 0 16rpx 42rpx rgba(20, 20, 19, 0.22);
  flex: 0 0 auto;
  margin: 0 22rpx calc(20rpx + env(safe-area-inset-bottom));
  overflow: hidden;
  width: calc(100% - 44rpx);
}

.composer.focused {
  border-color: #c9674f;
  box-shadow: 0 0 0 5rpx rgba(201, 103, 79, 0.2), 0 18rpx 46rpx rgba(20, 20, 19, 0.24);
}

.input {
  background: #1c1915;
  box-sizing: border-box;
  color: #fff7ed;
  font-size: 29rpx;
  line-height: 1.52;
  max-height: 220rpx;
  min-height: 112rpx;
  padding: 26rpx 28rpx 14rpx;
  width: 100%;
}

.input-placeholder {
  color: #a09d96;
}

.attachment-strip {
  background: #1c1915;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  padding: 0 24rpx 14rpx;
}

.attachment-chip {
  align-items: center;
  background: #252320;
  border: 1rpx solid #3a3731;
  border-radius: 12rpx;
  color: #fff7ed;
  display: flex;
  font-size: 22rpx;
  gap: 10rpx;
  max-width: 420rpx;
  padding: 10rpx 14rpx;
}

.attachment-chip text:first-child {
  max-width: 330rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.remove-attachment {
  color: #c9674f;
  font-size: 24rpx;
  line-height: 1;
}

.composer-toolbar {
  align-items: center;
  background: #1c1915;
  border-top: 1rpx solid #332d25;
  display: flex;
  gap: 12rpx;
  justify-content: space-between;
  padding: 12rpx 14rpx 14rpx 16rpx;
}

.tool-scroll {
  flex: 1;
  min-width: 0;
  white-space: nowrap;
}

.tool-pills {
  align-items: center;
  display: inline-flex;
  gap: 9rpx;
  white-space: nowrap;
}

.tool-pill {
  align-items: center;
  background: #29251f;
  border: 1rpx solid #40382f;
  border-radius: 999rpx;
  color: #d6d1c8;
  display: inline-flex;
  font-size: 22rpx;
  height: 52rpx;
  justify-content: center;
  line-height: 1;
  max-width: 238rpx;
  overflow: hidden;
  padding: 0 17rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-pill.active {
  background: rgba(201, 103, 79, 0.18);
  border-color: rgba(201, 103, 79, 0.58);
  color: #f0b49e;
}

.tool-pills .icon-pill {
  align-items: center;
  background: #fff7ed;
  border-color: #fff7ed;
  color: #171511;
  flex: 0 0 52rpx;
  font-size: 28rpx;
  height: 52rpx;
  justify-content: center;
  padding: 0;
  width: 52rpx;
}

.pill-icon {
  border-color: currentColor;
  color: inherit;
  display: inline-block;
  height: 22rpx;
  margin-right: 8rpx;
  position: relative;
  width: 22rpx;
}

.send-button {
  align-items: center;
  background: #c9674f;
  border-radius: 999rpx;
  color: #ffffff;
  display: flex;
  flex: 0 0 62rpx;
  font-size: 34rpx;
  height: 62rpx;
  justify-content: center;
  line-height: 62rpx;
  padding: 0;
  width: 62rpx;
}

.send-button[disabled] {
  background: #34312d;
  color: #77736b;
}

.cancel-button {
  background: #171511;
}

.clip-icon,
.mode-icon,
.tool-icon,
.book-icon,
.shelf-icon {
  border-color: currentColor;
  display: inline-block;
  position: relative;
}

.clip-icon {
  border: 3rpx solid;
  border-radius: 10rpx;
  height: 25rpx;
  transform: rotate(-12deg);
  width: 18rpx;
}

.clip-icon::after {
  border: 3rpx solid;
  border-radius: 8rpx;
  content: "";
  height: 14rpx;
  left: 5rpx;
  position: absolute;
  top: 4rpx;
  width: 8rpx;
}

.mode-icon {
  border: 3rpx solid;
  border-radius: 50%;
}

.mode-icon::after {
  background: currentColor;
  border-radius: 50%;
  content: "";
  height: 7rpx;
  left: 50%;
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 7rpx;
}

.tool-icon {
  border-left: 3rpx solid;
  border-right: 3rpx solid;
}

.tool-icon::before,
.tool-icon::after {
  background: currentColor;
  border-radius: 50%;
  content: "";
  height: 7rpx;
  position: absolute;
  top: 7rpx;
  width: 7rpx;
}

.tool-icon::before {
  left: 2rpx;
}

.tool-icon::after {
  right: 2rpx;
}

.book-icon {
  border: 3rpx solid;
  border-radius: 4rpx 8rpx 8rpx 4rpx;
}

.book-icon::after {
  border-left: 3rpx solid;
  content: "";
  height: 20rpx;
  left: 8rpx;
  position: absolute;
  top: -2rpx;
}

.shelf-icon {
  border: 3rpx solid;
  border-radius: 5rpx;
}

.shelf-icon::before,
.shelf-icon::after {
  background: currentColor;
  content: "";
  height: 3rpx;
  left: 3rpx;
  position: absolute;
  right: 3rpx;
}

.shelf-icon::before {
  top: 6rpx;
}

.shelf-icon::after {
  bottom: 6rpx;
}

.overlay {
  background: rgba(20, 20, 19, 0.28);
  bottom: 0;
  left: 0;
  position: fixed;
  right: 0;
  top: 0;
  z-index: 20;
}

.session-drawer {
  background: #171511;
  border-right: 1rpx solid #2b2721;
  bottom: 0;
  left: 0;
  position: fixed;
  top: 0;
  width: 610rpx;
  z-index: 21;
}

.drawer-head {
  align-items: center;
  border-bottom: 1rpx solid #2b2721;
  display: flex;
  justify-content: space-between;
  padding: 32rpx 24rpx 24rpx;
}

.drawer-kicker {
  color: #e7a38b;
  display: block;
  font-size: 21rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.drawer-title {
  color: #fff7ed;
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 36rpx;
  font-weight: 400;
  line-height: 1.2;
  margin-top: 8rpx;
}

.session-list {
  height: calc(100vh - 128rpx);
  padding: 18rpx 18rpx 28rpx;
}

.drawer-empty {
  color: #b7aea1;
  padding: 48rpx 12rpx;
  text-align: center;
}

.session-item {
  border-radius: 14rpx;
  padding: 18rpx 16rpx;
}

.session-item.active {
  background: #29251f;
}

.session-title {
  color: #fff7ed;
  font-size: 27rpx;
  font-weight: 500;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.session-preview {
  color: #b7aea1;
  font-size: 23rpx;
  line-height: 1.4;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
