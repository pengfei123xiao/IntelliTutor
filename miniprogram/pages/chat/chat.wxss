.chat-page {
  background: #faf9f5;
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.chat-topbar {
  align-items: center;
  background: #faf9f5;
  border-bottom: 1rpx solid #ebe6df;
  display: flex;
  justify-content: space-between;
  min-height: 92rpx;
  padding: 16rpx 24rpx;
}

.brand-block {
  align-items: center;
  display: flex;
  flex: 0 0 42rpx;
  gap: 12rpx;
  min-width: 0;
  overflow: hidden;
}

.brand-mark {
  color: #cc785c;
  font-size: 28rpx;
  line-height: 1;
}

.brand-name {
  color: #141413;
  display: none;
  font-size: 31rpx;
  font-weight: 500;
  max-width: 172rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.top-actions {
  display: flex;
  flex: 0 0 auto;
  gap: 10rpx;
}

.top-button {
  background: #faf9f5;
  border: 1rpx solid #e6dfd8;
  border-radius: 999rpx;
  color: #6c6a64;
  font-size: 23rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 18rpx;
}

.top-button.primary {
  background: #181715;
  border-color: #181715;
  color: #faf9f5;
}

.button-icon {
  display: inline-block;
  font-size: 22rpx;
  margin-right: 7rpx;
}

.message-list {
  flex: 1;
  min-height: 0;
  padding: 34rpx 32rpx 24rpx;
}

.message-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 26rpx;
}

.message-head text {
  color: #6c6a64;
  font-size: 24rpx;
  font-weight: 500;
}

.small-outline {
  background: #faf9f5;
  border: 1rpx solid #e6dfd8;
  border-radius: 14rpx;
  color: #6c6a64;
  font-size: 23rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 18rpx;
}

.empty-chat {
  align-items: center;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 58vh;
  text-align: center;
}

.empty-title {
  color: #141413;
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 48rpx;
  font-weight: 400;
  line-height: 1.16;
}

.empty-copy {
  color: #6c6a64;
  font-size: 26rpx;
  line-height: 1.55;
  margin-top: 18rpx;
}

.empty-prompts {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 34rpx;
  width: 100%;
}

.empty-prompts view {
  background: #efe9de;
  border: 1rpx solid #e6dfd8;
  border-radius: 16rpx;
  color: #3d3d3a;
  font-size: 27rpx;
  line-height: 1.45;
  padding: 22rpx 24rpx;
  text-align: left;
}

.message {
  display: flex;
  margin-bottom: 26rpx;
}

.message.user {
  justify-content: flex-end;
}

.message.assistant,
.message.status {
  justify-content: flex-start;
}

.bubble {
  font-size: 29rpx;
  line-height: 1.68;
  max-width: 88%;
  padding: 0;
  word-break: break-word;
}

.user .bubble {
  background: #efe9de;
  border-radius: 28rpx;
  color: #141413;
  padding: 20rpx 24rpx;
}

.assistant .bubble {
  color: #141413;
  max-width: 100%;
}

.assistant .bubble text {
  white-space: pre-wrap;
}

.message-attachments {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.message-attachments text {
  background: #faf9f5;
  border: 1rpx solid #e6dfd8;
  border-radius: 999rpx;
  color: #6c6a64;
  font-size: 22rpx;
  max-width: 360rpx;
  overflow: hidden;
  padding: 8rpx 14rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.message-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 14rpx;
}

.message-actions text {
  color: #8e8b82;
  font-size: 22rpx;
}

.status .bubble {
  background: #f5f0e8;
  border: 1rpx solid #e6dfd8;
  border-radius: 14rpx;
  color: #a9583e;
  font-size: 24rpx;
  padding: 12rpx 16rpx;
}

.composer {
  background: #1f1e1b;
  border: 1rpx solid #34312d;
  border-radius: 22rpx;
  box-shadow: 0 16rpx 42rpx rgba(20, 20, 19, 0.22);
  margin: 0 22rpx calc(20rpx + env(safe-area-inset-bottom));
  overflow: hidden;
}

.composer.focused {
  border-color: #cc785c;
  box-shadow: 0 0 0 5rpx rgba(204, 120, 92, 0.18), 0 18rpx 46rpx rgba(20, 20, 19, 0.24);
}

.input {
  background: #1f1e1b;
  color: #faf9f5;
  font-size: 29rpx;
  line-height: 1.52;
  max-height: 220rpx;
  min-height: 112rpx;
  padding: 26rpx 28rpx 14rpx;
  width: 100%;
}

.input-placeholder {
  color: #a09d96;
}

.attachment-strip {
  background: #1f1e1b;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  padding: 0 24rpx 14rpx;
}

.attachment-chip {
  align-items: center;
  background: #252320;
  border: 1rpx solid #3a3731;
  border-radius: 12rpx;
  color: #faf9f5;
  display: flex;
  font-size: 22rpx;
  gap: 10rpx;
  max-width: 420rpx;
  padding: 10rpx 14rpx;
}

.attachment-chip text:first-child {
  max-width: 330rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.remove-attachment {
  color: #cc785c;
  font-size: 24rpx;
  line-height: 1;
}

.composer-toolbar {
  align-items: center;
  background: #1f1e1b;
  border-top: 1rpx solid #34312d;
  display: flex;
  gap: 12rpx;
  justify-content: space-between;
  padding: 12rpx 14rpx 14rpx 16rpx;
}

.tool-scroll {
  flex: 1;
  min-width: 0;
  white-space: nowrap;
}

.tool-pills {
  align-items: center;
  display: inline-flex;
  gap: 9rpx;
  white-space: nowrap;
}

.tool-pill {
  align-items: center;
  background: #252320;
  border: 1rpx solid #3a3731;
  border-radius: 999rpx;
  color: #d6d1c8;
  display: inline-flex;
  font-size: 22rpx;
  height: 52rpx;
  justify-content: center;
  line-height: 1;
  max-width: 238rpx;
  overflow: hidden;
  padding: 0 17rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tool-pill.active {
  background: rgba(204, 120, 92, 0.16);
  border-color: rgba(204, 120, 92, 0.55);
  color: #f0b49e;
}

.tool-pills .icon-pill {
  align-items: center;
  background: #faf9f5;
  border-color: #faf9f5;
  color: #181715;
  flex: 0 0 52rpx;
  font-size: 28rpx;
  height: 52rpx;
  justify-content: center;
  padding: 0;
  width: 52rpx;
}

.pill-icon {
  color: inherit;
  font-size: 21rpx;
  margin-right: 8rpx;
}

.send-button {
  align-items: center;
  background: #cc785c;
  border-radius: 999rpx;
  color: #ffffff;
  display: flex;
  flex: 0 0 62rpx;
  font-size: 34rpx;
  height: 62rpx;
  justify-content: center;
  line-height: 62rpx;
  padding: 0;
  width: 62rpx;
}

.send-button[disabled] {
  background: #34312d;
  color: #77736b;
}

.cancel-button {
  background: #181715;
}

.overlay {
  background: rgba(20, 20, 19, 0.28);
  bottom: 0;
  left: 0;
  position: fixed;
  right: 0;
  top: 0;
  z-index: 20;
}

.session-drawer {
  background: #faf9f5;
  border-right: 1rpx solid #e6dfd8;
  bottom: 0;
  left: 0;
  position: fixed;
  top: 0;
  width: 610rpx;
  z-index: 21;
}

.drawer-head {
  align-items: center;
  border-bottom: 1rpx solid #e6dfd8;
  display: flex;
  justify-content: space-between;
  padding: 32rpx 24rpx 24rpx;
}

.drawer-kicker {
  color: #cc785c;
  display: block;
  font-size: 21rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.drawer-title {
  color: #141413;
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 36rpx;
  font-weight: 400;
  line-height: 1.2;
  margin-top: 8rpx;
}

.session-list {
  height: calc(100vh - 128rpx);
  padding: 18rpx 18rpx 28rpx;
}

.drawer-empty {
  color: #6c6a64;
  padding: 48rpx 12rpx;
  text-align: center;
}

.session-item {
  border-radius: 14rpx;
  padding: 18rpx 16rpx;
}

.session-item.active {
  background: #efe9de;
}

.session-title {
  color: #141413;
  font-size: 27rpx;
  font-weight: 500;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.session-preview {
  color: #6c6a64;
  font-size: 23rpx;
  line-height: 1.4;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
