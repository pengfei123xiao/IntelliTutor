<view class="chat-page">
  <view class="chat-topbar">
    <button class="top-button" bindtap="toggleSessions"><text class="button-icon history-icon"></text>历史</button>
    <view class="top-actions">
      <button class="top-button primary" bindtap="newChat"><text class="button-icon plus-icon"></text>新对话</button>
    </view>
  </view>

  <scroll-view class="message-list" scroll-y scroll-with-animation scroll-into-view="{{scrollIntoView}}">
    <view class="message-content">
    <view wx:if="{{messages.length === 0}}" class="empty-chat">
      <view class="empty-orbit">
        <text class="orbit-mark">问</text>
      </view>
      <view class="empty-kicker">像网页端一样从一个问题开始</view>
      <view class="empty-title">今天想学什么？</view>
      <view class="empty-copy">直接输入问题，或选择资料后开启带读、测评和复盘。</view>
      <view class="empty-prompts">
        <view bindtap="usePrompt" data-text="请用提问的方式带我学习这一节内容">
          <text class="prompt-icon">问</text>
          <text class="prompt-title">苏格拉底带读</text>
          <text class="prompt-desc">边问边想，适合预习和课堂讲解</text>
        </view>
        <view bindtap="usePrompt" data-text="根据当前资料帮我出三道检测题">
          <text class="prompt-icon coral">测</text>
          <text class="prompt-title">生成检测题</text>
          <text class="prompt-desc">快速看懂学生是否真正掌握</text>
        </view>
        <view bindtap="usePrompt" data-text="这一章的知识点路径是什么？">
          <text class="prompt-icon gold">路</text>
          <text class="prompt-title">知识点路径</text>
          <text class="prompt-desc">把章节拆成今日可执行任务</text>
        </view>
      </view>
    </view>

    <view wx:if="{{messages.length > 0}}" class="message-head">
      <text>{{activeCapabilityLabel}}</text>
      <button class="small-outline" bindtap="newChat">新对话</button>
    </view>

    <block wx:for="{{messages}}" wx:key="id">
      <view id="msg-{{item.id}}" class="message {{item.role}}">
        <view class="bubble">
          <text class="message-text">{{item.content}}</text>
          <view wx:if="{{item.attachments.length}}" class="message-attachments">
            <block wx:for="{{item.attachments}}" wx:for-item="attachment" wx:key="filename">
              <text>{{attachment.filename}}</text>
            </block>
          </view>
          <view wx:if="{{item.content}}" class="message-actions">
            <text data-id="{{item.id}}" bindtap="copyMessage">复制</text>
            <text wx:if="{{item.role === 'assistant'}}" data-id="{{item.id}}" bindtap="retryFromMessage">重试</text>
            <text wx:if="{{item.role === 'assistant'}}" data-id="{{item.id}}" bindtap="saveMessageToNotebook">保存</text>
          </view>
          <text wx:if="{{item.role === 'assistant' && item.content}}" class="ai-note">AI 生成内容仅供参考</text>
        </view>
      </view>
    </block>
    <view id="bottom"></view>
    </view>
  </scroll-view>

  <view class="composer {{inputFocused ? 'focused' : ''}}">
    <textarea
      class="input"
      value="{{draft}}"
      auto-height
      maxlength="800"
      cursor-spacing="24"
      placeholder="输入你的问题"
      placeholder-class="input-placeholder"
      bindinput="onDraftInput"
      bindfocus="onInputFocus"
      bindblur="onInputBlur"
      confirm-type="send"
    />
    <view wx:if="{{attachments.length}}" class="attachment-strip">
      <block wx:for="{{attachments}}" wx:key="filename">
        <view class="attachment-chip">
          <text>{{item.filename}}</text>
          <text class="remove-attachment" data-index="{{index}}" bindtap="removeAttachment">×</text>
        </view>
      </block>
    </view>
    <view class="composer-toolbar">
      <scroll-view scroll-x class="tool-scroll" show-scrollbar="{{false}}">
        <view class="tool-pills">
          <view class="tool-pill icon-pill" bindtap="chooseAttachment"><text class="clip-icon"></text></view>
          <view class="tool-pill" bindtap="chooseCapability"><text class="pill-icon mode-icon"></text>{{activeCapabilityLabel}}</view>
          <view class="tool-pill {{enabledTools.length ? 'active' : ''}}" bindtap="chooseTools"><text class="pill-icon tool-icon"></text>学习工具{{enabledTools.length ? " " + enabledTools.length : ""}}</view>
          <view class="tool-pill {{ragEnabled ? 'active' : ''}}" bindtap="toggleRag"><text class="pill-icon book-icon"></text>资料问答</view>
          <view class="tool-pill" bindtap="chooseKnowledgeBase"><text class="pill-icon shelf-icon"></text>{{activeKnowledgeBase || "选择资料"}}</view>
        </view>
      </scroll-view>
      <button wx:if="{{streaming}}" class="send-button cancel-button" bindtap="cancelStreaming">×</button>
      <button wx:else class="send-button" disabled="{{!draft && !attachments.length}}" bindtap="sendMessage">↑</button>
    </view>
  </view>

  <view wx:if="{{sessionsOpen}}" class="overlay" bindtap="toggleSessions"></view>
  <view wx:if="{{sessionsOpen}}" class="session-drawer">
    <view class="drawer-head">
      <view>
        <text class="drawer-kicker">最近</text>
        <view class="drawer-title">历史对话</view>
      </view>
      <button class="top-button" bindtap="refreshSessions">刷新</button>
    </view>
    <scroll-view scroll-y class="session-list">
      <view wx:if="{{sessions.length === 0}}" class="drawer-empty">暂无会话</view>
      <block wx:for="{{sessions}}" wx:key="session_id">
        <view class="session-item {{item.session_id === sessionId ? 'active' : ''}}" data-id="{{item.session_id}}" bindtap="loadSession">
          <view class="session-title">{{item.title || "未命名对话"}}</view>
          <view class="session-preview">{{item.last_message || item.message_count + " 条消息"}}</view>
        </view>
      </block>
    </scroll-view>
  </view>
</view>
