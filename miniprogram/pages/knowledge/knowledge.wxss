.header-band {
  border-bottom: 1rpx solid #ebe6df;
  padding-bottom: 24rpx;
}

.tabs {
  border-bottom: 1rpx solid #e6dfd8;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin-bottom: 24rpx;
}

.tabs view {
  align-items: center;
  color: #6c6a64;
  display: flex;
  font-size: 25rpx;
  justify-content: center;
  line-height: 72rpx;
  text-align: center;
}

.tabs view.active {
  border-bottom: 3rpx solid #c9674f;
  color: #c9674f;
  font-weight: 500;
}

.toolbar {
  display: grid;
  gap: 18rpx;
  grid-template-columns: 1fr 1fr;
}

.kb-card,
.notebook,
.question-card {
  background: transparent;
  border-width: 0 0 1rpx;
  border-radius: 0;
  margin-bottom: 0;
  padding: 24rpx 0;
  position: relative;
}

.kb-card.selected {
  background: transparent;
  border-color: #c9674f;
}

.kb-card.selected .kb-title {
  color: #c9674f;
}

.kb-card.selected .subtitle,
.kb-card.selected .stats {
  color: #6c6a64;
}

.kb-title {
  color: #141413;
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 34rpx;
  line-height: 1.25;
}

.kb-main {
  flex: 1;
  min-width: 0;
}

.select-button {
  height: 64rpx;
  line-height: 64rpx;
  min-width: 112rpx;
  padding: 0 22rpx;
}

.stats {
  color: #6c6a64;
  display: flex;
  font-size: 24rpx;
  gap: 28rpx;
  margin-top: 14rpx;
}

.wide-dark {
  background: #171511;
  border-radius: 16rpx;
  color: #fff7ed;
  font-size: 27rpx;
  height: 78rpx;
  line-height: 78rpx;
  margin-top: 12rpx;
}

.filter-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.filter-row text {
  background: #f7efe5;
  border: 1rpx solid #e2d5c6;
  border-radius: 999rpx;
  color: #6c6a64;
  font-size: 24rpx;
  padding: 14rpx 22rpx;
}

.filter-row text.active {
  background: #c9674f;
  border-color: #c9674f;
  color: #ffffff;
}

.question-title {
  color: #141413;
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.45;
  margin-right: 18rpx;
}

.tag.wrong {
  color: #c64545;
}

.explain {
  border-left: 4rpx solid #e6dfd8;
  color: #3d3d3a;
  font-size: 25rpx;
  line-height: 1.55;
  margin-top: 18rpx;
  padding-left: 18rpx;
}

.question-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 18rpx;
}

.question-actions text {
  color: #c9674f;
  font-size: 24rpx;
}
