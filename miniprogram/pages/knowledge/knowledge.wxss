.header-band {
  border-bottom: 1rpx solid #ebe6df;
  padding-bottom: 28rpx;
}

.header-row {
  align-items: center;
  display: flex;
  gap: 18rpx;
}

.tabs {
  background: #f7efe5;
  border: 1rpx solid #e2d5c6;
  border-radius: 16rpx;
  display: grid;
  gap: 8rpx;
  grid-template-columns: repeat(3, 1fr);
  margin-bottom: 28rpx;
  padding: 8rpx;
}

.tabs view {
  align-items: center;
  border-radius: 12rpx;
  color: #6c6a64;
  display: flex;
  font-size: 25rpx;
  gap: 8rpx;
  justify-content: center;
  line-height: 62rpx;
  text-align: center;
}

.tabs text {
  align-items: center;
  background: rgba(201, 103, 79, 0.14);
  border-radius: 50%;
  color: #c9674f;
  display: flex;
  font-size: 20rpx;
  height: 34rpx;
  justify-content: center;
  line-height: 1;
  width: 34rpx;
}

.tabs view.active {
  background: #171511;
  color: #fff7ed;
}

.tabs view.active text {
  background: #c9674f;
  color: #fff7ed;
}

.toolbar {
  display: grid;
  gap: 18rpx;
  grid-template-columns: 1fr 1fr;
}

.kb-card,
.notebook,
.question-card {
  background: #f3eadc;
  margin-bottom: 18rpx;
  position: relative;
}

.kb-card.selected {
  background: #171511;
  border-color: #2b2721;
}

.kb-card.selected .kb-title,
.kb-card.selected .card-icon {
  color: #fff7ed;
}

.kb-card.selected .subtitle,
.kb-card.selected .stats {
  color: #a09d96;
}

.kb-title {
  color: #141413;
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 36rpx;
  line-height: 1.25;
}

.kb-main {
  flex: 1;
  min-width: 0;
}

.card-icon {
  align-items: center;
  background: #171511;
  border-radius: 16rpx;
  color: #fff7ed;
  display: flex;
  flex: 0 0 62rpx;
  font-size: 26rpx;
  font-weight: 600;
  height: 62rpx;
  justify-content: center;
  margin-right: 18rpx;
  width: 62rpx;
}

.card-icon.note {
  background: #d89945;
}

.card-icon.question {
  background: #c9674f;
}

.select-button {
  height: 64rpx;
  line-height: 64rpx;
  min-width: 112rpx;
  padding: 0 22rpx;
}

.stats {
  border-top: 1rpx solid #e2d5c6;
  color: #6c6a64;
  display: flex;
  font-size: 24rpx;
  gap: 28rpx;
  margin-top: 22rpx;
  padding-top: 18rpx;
}

.kb-card.selected .stats {
  border-top-color: #252320;
}

.wide-dark {
  background: #171511;
  border-radius: 16rpx;
  color: #fff7ed;
  font-size: 27rpx;
  height: 78rpx;
  line-height: 78rpx;
  margin-top: 12rpx;
}

.filter-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.filter-row text {
  background: #f7efe5;
  border: 1rpx solid #e2d5c6;
  border-radius: 999rpx;
  color: #6c6a64;
  font-size: 24rpx;
  padding: 14rpx 22rpx;
}

.filter-row text.active {
  background: #c9674f;
  border-color: #c9674f;
  color: #ffffff;
}

.question-title {
  color: #141413;
  flex: 1;
  font-size: 29rpx;
  font-weight: 500;
  line-height: 1.45;
  margin-right: 18rpx;
}

.tag.wrong {
  color: #c64545;
}

.explain {
  background: #fbf6ee;
  border-radius: 12rpx;
  color: #3d3d3a;
  font-size: 25rpx;
  line-height: 1.55;
  margin-top: 18rpx;
  padding: 18rpx;
}

.question-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 18rpx;
}

.question-actions text {
  color: #c9674f;
  font-size: 24rpx;
}
