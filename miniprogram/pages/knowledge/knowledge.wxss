.header-band {
  border-bottom: 1rpx solid #ebe6df;
  padding-bottom: 28rpx;
}

.tabs {
  background: #f5f0e8;
  border: 1rpx solid #e6dfd8;
  border-radius: 16rpx;
  display: grid;
  gap: 8rpx;
  grid-template-columns: repeat(3, 1fr);
  margin-bottom: 28rpx;
  padding: 8rpx;
}

.tabs view {
  border-radius: 12rpx;
  color: #6c6a64;
  font-size: 25rpx;
  line-height: 62rpx;
  text-align: center;
}

.tabs view.active {
  background: #181715;
  color: #faf9f5;
}

.toolbar {
  display: grid;
  gap: 18rpx;
  grid-template-columns: 1fr 1fr;
}

.kb-card,
.notebook,
.question-card {
  background: #efe9de;
  margin-bottom: 18rpx;
  position: relative;
}

.kb-card.selected {
  background: #181715;
  border-color: #252320;
}

.kb-card.selected .kb-title {
  color: #faf9f5;
}

.kb-card.selected .subtitle,
.kb-card.selected .stats {
  color: #a09d96;
}

.kb-title {
  color: #141413;
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 36rpx;
  line-height: 1.25;
}

.kb-main {
  flex: 1;
  min-width: 0;
}

.select-button {
  height: 64rpx;
  line-height: 64rpx;
  min-width: 112rpx;
  padding: 0 22rpx;
}

.stats {
  border-top: 1rpx solid #e6dfd8;
  color: #6c6a64;
  display: flex;
  font-size: 24rpx;
  gap: 28rpx;
  margin-top: 22rpx;
  padding-top: 18rpx;
}

.kb-card.selected .stats {
  border-top-color: #252320;
}

.wide-dark {
  background: #181715;
  border-radius: 16rpx;
  color: #faf9f5;
  font-size: 27rpx;
  height: 78rpx;
  line-height: 78rpx;
  margin-top: 12rpx;
}

.filter-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.filter-row text {
  background: #f5f0e8;
  border: 1rpx solid #e6dfd8;
  border-radius: 999rpx;
  color: #6c6a64;
  font-size: 24rpx;
  padding: 14rpx 22rpx;
}

.filter-row text.active {
  background: #cc785c;
  border-color: #cc785c;
  color: #ffffff;
}

.question-title {
  color: #141413;
  flex: 1;
  font-size: 29rpx;
  font-weight: 500;
  line-height: 1.45;
  margin-right: 18rpx;
}

.tag.wrong {
  color: #c64545;
}

.explain {
  background: #faf9f5;
  border-radius: 12rpx;
  color: #3d3d3a;
  font-size: 25rpx;
  line-height: 1.55;
  margin-top: 18rpx;
  padding: 18rpx;
}

.question-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 18rpx;
}

.question-actions text {
  color: #cc785c;
  font-size: 24rpx;
}
