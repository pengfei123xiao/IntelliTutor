.hero-panel {
  border-bottom: 1rpx solid #ebe6df;
  padding-bottom: 26rpx;
}

.report-strip {
  border-bottom: 1rpx solid #e6dfd8;
  border-top: 1rpx solid #e6dfd8;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  padding: 18rpx 0;
}

.metric {
  background: transparent;
  border-right: 1rpx solid #e6dfd8;
  border-radius: 0;
  padding: 4rpx 14rpx;
  text-align: center;
}

.metric:last-child {
  border-right: 0;
}

.metric-value {
  color: #141413;
  display: block;
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 36rpx;
  line-height: 1;
}

.metric-label {
  color: #6c6a64;
  display: block;
  font-size: 22rpx;
  margin-top: 10rpx;
}

.report-card {
  background: transparent;
  border-bottom: 1rpx solid #e6dfd8;
  border-radius: 0;
  padding: 0 0 28rpx;
}

.section-heading {
  color: #141413;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 1.35;
}

.mastery-row {
  align-items: flex-end;
  display: flex;
  gap: 22rpx;
  margin-top: 18rpx;
}

.mastery-number {
  color: #141413;
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 58rpx;
  line-height: 1;
}

.mastery-copy {
  color: #141413;
  flex: 1;
  font-size: 27rpx;
  line-height: 1.45;
}

.mastery-copy text {
  color: #6c6a64;
  display: block;
  font-size: 23rpx;
  margin-top: 4rpx;
}

.progress-track {
  background: #e6dfd8;
  border-radius: 999rpx;
  height: 12rpx;
  margin-top: 18rpx;
  overflow: hidden;
}

.progress-fill {
  background: #c9674f;
  border-radius: 999rpx;
  height: 100%;
}

.prompt-actions {
  display: grid;
  gap: 14rpx;
  grid-template-columns: 1fr 1fr;
  margin-top: 18rpx;
}

.node-row,
.graph-row,
.suggestion-row,
.recent-row {
  border-top: 1rpx solid #e6dfd8;
  color: #3d3d3a;
  font-size: 26rpx;
  line-height: 1.5;
  margin-top: 18rpx;
  padding-top: 18rpx;
}

.node-title {
  color: #141413;
  font-size: 27rpx;
  font-weight: 500;
  line-height: 1.4;
  margin-bottom: 6rpx;
}

.node-row text,
.graph-row text,
.recent-row text {
  color: #6c6a64;
  display: block;
  font-size: 23rpx;
}

.graph-row {
  align-items: flex-start;
  display: flex;
  gap: 18rpx;
  justify-content: space-between;
}

.graph-value {
  color: #141413;
  flex: 0 0 180rpx;
  font-size: 25rpx;
  text-align: right;
}

.suggestion-row {
  color: #141413;
}

.share-summary {
  border-left: 4rpx solid #c9674f;
  color: #141413;
  font-size: 28rpx;
  line-height: 1.6;
  margin-top: 18rpx;
  padding-left: 18rpx;
}
