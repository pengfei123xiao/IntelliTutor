.hero-panel {
  border-bottom: 1rpx solid #ebe6df;
  padding-bottom: 30rpx;
}

.page > .section.panel {
  background: transparent;
  border-width: 0 0 1rpx;
  border-radius: 0;
  padding: 0 0 28rpx;
}

.grid {
  border-bottom: 1rpx solid #e6dfd8;
  border-top: 1rpx solid #e6dfd8;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  padding: 18rpx 0;
}

.metric {
  background: transparent;
  border-width: 0 1rpx 0 0;
  border-radius: 0;
  padding: 4rpx 14rpx;
  text-align: center;
}

.metric:last-child {
  border-right: 0;
}

.metric-value {
  color: #141413;
  display: block;
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 38rpx;
  line-height: 1;
}

.metric-label {
  color: #6c6a64;
  display: block;
  font-size: 22rpx;
  margin-top: 10rpx;
}

.prompt-panel {
  background: transparent;
  border-width: 0 0 1rpx;
  border-radius: 0;
  padding: 0 0 28rpx;
}

.tip {
  border-left: 4rpx solid #c9674f;
  color: #141413;
  font-size: 28rpx;
  line-height: 1.6;
  margin-top: 20rpx;
  padding-left: 18rpx;
}

.prompt-actions {
  display: grid;
  gap: 14rpx;
  grid-template-columns: 1fr 1fr;
  margin-top: 18rpx;
}

.list-row {
  align-items: center;
  border-top: 1rpx solid #e6dfd8;
  color: #3d3d3a;
  display: flex;
  font-size: 26rpx;
  gap: 14rpx;
  line-height: 1.5;
  margin-top: 18rpx;
  padding-top: 18rpx;
}

.dot {
  background: #c9674f;
  border-radius: 50%;
  height: 12rpx;
  width: 12rpx;
}

.review-item,
.recent-item {
  border-top: 1rpx solid #e6dfd8;
  color: #141413;
  font-size: 27rpx;
  line-height: 1.5;
  margin-top: 18rpx;
  padding-top: 18rpx;
}

.recent-item text {
  color: #6c6a64;
  display: block;
  font-size: 23rpx;
  margin-top: 6rpx;
}
