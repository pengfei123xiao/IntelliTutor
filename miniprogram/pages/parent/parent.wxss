.hero-panel {
  border-bottom: 1rpx solid #ebe6df;
  padding-bottom: 30rpx;
}

.hero-row {
  align-items: center;
  display: flex;
  gap: 18rpx;
}

.grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: repeat(3, 1fr);
}

.metric {
  background: #f3eadc;
  padding: 26rpx 14rpx;
  text-align: center;
}

.metric-icon {
  align-items: center;
  background: #171511;
  border-radius: 12rpx;
  color: #fff7ed;
  display: flex;
  font-size: 21rpx;
  font-weight: 600;
  height: 42rpx;
  justify-content: center;
  margin: 0 auto 12rpx;
  width: 42rpx;
}

.metric-icon.coral {
  background: #c9674f;
}

.metric-icon.gold {
  background: #d89945;
}

.metric-value {
  color: #141413;
  display: block;
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 38rpx;
  line-height: 1;
}

.metric-label {
  color: #6c6a64;
  display: block;
  font-size: 22rpx;
  margin-top: 10rpx;
}

.prompt-panel {
  background: #171511;
  border-color: #2b2721;
}

.prompt-panel .card-title {
  color: #fff7ed;
}

.tip {
  background: #c9674f;
  border-radius: 16rpx;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.6;
  margin-top: 20rpx;
  padding: 24rpx;
}

.prompt-actions {
  display: grid;
  gap: 14rpx;
  grid-template-columns: 1fr 1fr;
  margin-top: 18rpx;
}

.prompt-panel .button-secondary {
  background: #29251f;
  border-color: #3a3731;
  color: #fff7ed;
}

.inline-icon {
  align-items: center;
  background: #c9674f;
  border-radius: 10rpx;
  color: #fff7ed;
  display: inline-flex;
  font-size: 20rpx;
  height: 36rpx;
  justify-content: center;
  margin-right: 10rpx;
  vertical-align: middle;
  width: 36rpx;
}

.inline-icon.coral {
  background: #c9674f;
}

.inline-icon.gold {
  background: #d89945;
}

.inline-icon.dark {
  background: #171511;
}

.list-row {
  align-items: center;
  border-top: 1rpx solid #e6dfd8;
  color: #3d3d3a;
  display: flex;
  font-size: 26rpx;
  gap: 14rpx;
  line-height: 1.5;
  margin-top: 18rpx;
  padding-top: 18rpx;
}

.dot {
  background: #c9674f;
  border-radius: 50%;
  height: 12rpx;
  width: 12rpx;
}

.review-item,
.recent-item {
  border-top: 1rpx solid #e6dfd8;
  color: #141413;
  font-size: 27rpx;
  line-height: 1.5;
  margin-top: 18rpx;
  padding-top: 18rpx;
}

.recent-item text {
  color: #6c6a64;
  display: block;
  font-size: 23rpx;
  margin-top: 6rpx;
}
